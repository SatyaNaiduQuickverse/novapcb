	(footprint "ESC_solder_pad"
		(layer "F.Cu")
		(uuid "81fcb8dd-ee3a-4846-a5c1-20b7e825b1dd")
		(at 13.5 2)
		(descr "ESC motor-output solder pad pair (signal + GND), 2.0x1.5mm SMD pads at 2.5mm pitch. Per CLAUDE.md §3.4 logic-level 3.3V, no power passthrough on motor connectors (ESCs powered direct-from-battery). MatekH743-style mini-FC convention. Pad 1 = signal (MOTn), Pad 2 = GND.")
